---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/dev-pages.css";
import { ruLandingCards } from "../../data/landingPages.ru";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Главная",
          item: "https://moldovawebsite.md/ru/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Цены",
          item: "https://moldovawebsite.md/ru/preturi/",
        },
      ],
    },
    {
      "@type": "Service",
      serviceType: "Создание сайта",
      name: "Создание сайтов в Молдове",
      description:
        "Пакеты для лендинга, сайта-визитки и мини-магазина с ценами от 50€.",
      provider: {
        "@type": "ProfessionalService",
        name: "moldovawebsite.md",
      },
      areaServed: { "@type": "Country", name: "Молдова" },
      url: "https://moldovawebsite.md/ru/preturi/",
      offers: {
        "@type": "AggregateOffer",
        lowPrice: "50",
        highPrice: "300",
        offerCount: "3",
        priceCurrency: "EUR",
        availability: "https://schema.org/InStock",
      },
    },
    {
      "@type": "OfferCatalog",
      name: "Пакеты создания сайтов - Молдова",
      url: "https://moldovawebsite.md/ru/preturi/",
      itemListElement: [
        {
          "@type": "Offer",
          name: "Basic",
          url: "https://moldovawebsite.md/ru/preturi/#pachet-basic",
          price: "50",
          priceCurrency: "EUR",
          availability: "https://schema.org/InStock",
          itemOffered: {
            "@type": "Service",
            name: "Лендинг (1 страница)",
            areaServed: { "@type": "Country", name: "Молдова" },
          },
        },
        {
          "@type": "Offer",
          name: "Standard",
          url: "https://moldovawebsite.md/ru/preturi/#pachet-standard",
          price: "150",
          priceCurrency: "EUR",
          availability: "https://schema.org/InStock",
          itemOffered: {
            "@type": "Service",
            name: "Сайт-визитка (до 5 страниц)",
            areaServed: { "@type": "Country", name: "Молдова" },
          },
        },
        {
          "@type": "Offer",
          name: "Pro",
          url: "https://moldovawebsite.md/ru/preturi/#pachet-pro",
          price: "300",
          priceCurrency: "EUR",
          availability: "https://schema.org/InStock",
          itemOffered: {
            "@type": "Service",
            name: "Продвинутый сайт / мини-магазин",
            areaServed: { "@type": "Country", name: "Молдова" },
          },
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "Сколько стоит создание сайта в Молдове?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Лендинг начинается от 50€, сайт-визитка от 150€, а мини-магазин от 300€. Финальная цена зависит от структуры, контента и функциональности.",
          },
        },
        {
          "@type": "Question",
          name: "Могу ли я оплатить в MDL или двумя частями?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Да. Счет может быть выставлен в EUR или эквиваленте MDL. Для пакетов Standard/Pro мы также принимаем оплату двумя частями (50% аванс, 50% при доставке).",
          },
        },
        {
          "@type": "Question",
          name: "Что включает SEO на странице?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Мета-теги, правильная структура страницы (H1–H3), оптимизация скорости, схема JSON-LD (где это актуально) и базовые настройки для индексации.",
          },
        },
        {
          "@type": "Question",
          name: "Включены ли домен и хостинг?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Нет. Мы рекомендуем варианты, подходящие для вашего бюджета, и помогаем с настройкой (DNS, SSL, электронная почта).",
          },
        },
        {
          "@type": "Question",
          name: "Смогу ли я самостоятельно изменять контент после запуска?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Да, пакеты Standard/Pro включают CMS (управление контентом). Мы также предоставляем небольшое руководство + обучение (в Pro).",
          },
        },
      ],
    },
  ],
};

const packages = [
  {
    id: "pachet-basic",
    name: "Basic",
    price: "50€",
    description: "Лендинг (1 страница) – быстрое и недорогое решение",
    features: [
      "Адаптивный дизайн для мобильных/планшетов",
      "Контактная форма, карта Google",
      "SSL, базовая оптимизация скорости",
      "Базовое SEO на странице (Заголовок, Meta, H1–H3)",
      "1 правка включена",
      "Сроки: 2–3 рабочих дня",
    ],
    note: "Домен и хостинг не включены. Мы можем помочь с настройкой.",
    featured: false,
  },
  {
    id: "pachet-standard",
    name: "Standard",
    price: "150€",
    description: "Сайт-визитка (до 5 страниц) + основная настройка",
    features: [
      "Современный дизайн и UX, ориентированный на конверсию",
      "Простая CMS (управление контентом)",
      "Расширенное SEO на странице + схема JSON-LD",
      "Настройка GA4 и Search Console",
      "2–3 правки включены",
      "Сроки: 7–10 рабочих дней",
    ],
    note: "Идеально для локального бизнеса, который хочет видимости в поиске.",
    featured: true,
  },
  {
    id: "pachet-pro",
    name: "Pro",
    price: "300€",
    description: "Продвинутый сайт (до 12 страниц) или мини-магазин",
    features: [
      "Индивидуальный дизайн + премиум-компоненты",
      "Мини-магазин (до 10 товаров), корзина, доставка и оплата",
      "Продвинутое SEO (структура, скорость, rich results)",
      "RO + RU (многоязычность) – опционально",
      "5 правок включены + 1 час обучения",
      "Сроки: 10–14 рабочих дней",
    ],
    note: "Включает 1 месяц базового обслуживания после запуска.",
    featured: false,
  },
];

const factors = [
  {
    title: "Количество страниц",
    description:
      "Сайт-визитка с 3–5 страницами проще, чем сайт с 10–15 страницами, что влияет на время работы и бюджет.",
  },
  {
    title: "Дизайн и идентичность",
    description:
      "Адаптированный шаблон или индивидуальный дизайн? Чем выше уровень персонализации, тем выше цена.",
  },
  {
    title: "Специальные функции",
    description:
      "Расширенные формы, бронирования, интеграция оплаты или мини-магазин требуют дополнительной разработки.",
  },
  {
    title: "SEO и контент",
    description:
      "SEO-оптимизация, тексты и изображения могут влиять на стоимость и результаты в Google.",
  },
];

const addons = [
  {
    title: "Логотип и визуальная идентичность",
    description: "От 30€ – основной вариант + набор для веба.",
  },
  {
    title: "SEO-копирайтинг",
    description: "От 10€/страница – оптимизированные тексты для RO/RU.",
  },
  {
    title: "Многоязычность RO/RU",
    description: "От 30€ – переведенные страницы + переключатель.",
  },
  {
    title: "Обслуживание",
    description:
      "От 25€/месяц – обновления, безопасность, резервное копирование.",
  },
];

const faqs = [
  {
    question: "Сколько стоит создание сайта в Молдове?",
    answer:
      "Лендинг начинается от 50€, сайт-визитка от 150€, а мини-магазин от 300€. Финальная цена зависит от структуры, контента и функциональности.",
  },
  {
    question: "Могу ли я оплатить в MDL или двумя частями?",
    answer:
      "Да. Счет может быть выставлен в EUR или эквиваленте MDL. Для пакетов Standard/Pro мы также принимаем оплату двумя частями (50% аванс, 50% при доставке).",
  },
  {
    question: "Что включает SEO на странице?",
    answer:
      "Мета-теги, правильная структура страницы (H1–H3), оптимизация скорости, схема JSON-LD (где это актуально) и базовые настройки для индексации.",
  },
  {
    question: "Включены ли домен и хостинг?",
    answer:
      "Нет. Мы рекомендуем варианты, подходящие для вашего бюджета, и помогаем с настройкой (DNS, SSL, электронная почта).",
  },
  {
    question: "Смогу ли я самостоятельно изменять контент после запуска?",
    answer:
      "Да, пакеты Standard/Pro включают CMS (управление контентом). Мы также предоставляем небольшое руководство + обучение (в Pro).",
  },
];

const whyChooseUs = [
  {
    icon: "🎯",
    title: "Честная цена",
    description:
      "Мы показываем точные цены без скрытых платежей. Вы знаете, за что платите.",
  },
  {
    icon: "⚡",
    title: "Быстрая разработка",
    description:
      "Современные технологии позволяют нам создавать сайты быстро без потери качества.",
  },
  {
    icon: "🔒",
    title: "Надежность",
    description:
      "Мы используем проверенные решения и предоставляем гарантию на все наши работы.",
  },
];

const testimonials = [
  {
    content:
      "Отличное соотношение цены и качества. Сайт был готов быстрее, чем ожидалось, и выглядит профессионально.",
    author: "Клиент из Кишинева",
  },
  {
    content:
      "Прозрачные цены, никаких сюрпризов. Оплатил 50% upfront, остальное после запуска. Рекомендую!",
    author: "Владелец бизнеса",
  },
];
---

<!doctype html>
<html lang="ru">
  <head>
    <BaseHead
      title="Сколько стоит сайт в Молдове? Цены 50-300€"
      description="Прозрачные цены на сайт в Молдове: лендинг 50€, сайт-визитка 150€, мини-магазин 300€. Быстрая оценка и бесплатный расчёт."
      canonicalUrl="https://moldovawebsite.md/ru/preturi/"
      lang="ru"
      ogLocale="ru_MD"
      hreflangRo="https://moldovawebsite.md/preturi/"
      hreflangRu="https://moldovawebsite.md/ru/preturi/"
      image="/assets/og-image-preturi.webp"
      jsonLd={jsonLd}
    />
    
  </head>
  <body>
    <div class="dev-grid-pattern"></div>
    <Header lang="ru" />

    <!-- Hero -->
    <section class="dev-hero">
      <div class="container">
        <div class="dev-hero-content">
          <span class="dev-section-tag">Цены</span>
          <h1>Сколько стоит сайт в Молдове? Цены и пакеты 2026</h1>
          <p>Сравните стоимость лендинга, сайта-визитки и мини-магазина: Basic 50€, Standard 150€, Pro 300€.</p>
          <p>Ориентиры для веб-дизайна в Кишиневе и по всей Молдове.</p>
        </div>
        <div class="dev-hero-intro">
          <p>
            Мы предлагаем прозрачное и честное ценообразование на создание
            сайтов в Молдове. Наша цель – сделать профессиональный веб-дизайн
            доступным для малого бизнеса. Все цены указаны в евро, но возможна
            оплата в леях по текущему курсу.
          </p>
          <p>
            Каждый пакет включает всё необходимое для запуска вашего сайта:
            дизайн, разработку, базовое SEO и обучение работе с сайтом. Никаких
            скрытых платежей – вы точно знаете, сколько заплатите.
          </p>
        </div>
      </div>
    </section>

    <!-- Quick Estimate -->
    <section class="dev-section dev-section-alt" id="bystraya-ocenka">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Быстрая оценка</span>
          <h2>Выберите ориентир по цене за 30 секунд</h2>
          <p>Быстрый сценарий до финального предложения.</p>
        </div>
        <div class="dev-pricing-grid">
          <article class="dev-price-card">
            <h3>Лендинг</h3>
            <div class="dev-price">~50€</div>
            <p>1 страница, быстрый запуск, форма заявки.</p>
            <a href="/ru/contact/" class="dev-btn dev-btn-secondary dev-btn-block">
              Выбрать Basic
            </a>
          </article>
          <article class="dev-price-card featured">
            <h3>Сайт-визитка</h3>
            <div class="dev-price">~150€</div>
            <p>3-5 страниц, базовое SEO и готовая структура.</p>
            <a href="/ru/contact/" class="dev-btn dev-btn-primary dev-btn-block">
              Выбрать Standard
            </a>
          </article>
          <article class="dev-price-card">
            <h3>Мини-магазин</h3>
            <div class="dev-price">~300€</div>
            <p>Каталог, корзина, доставка и старт e-commerce.</p>
            <a href="/ru/contact/" class="dev-btn dev-btn-secondary dev-btn-block">
              Выбрать Pro
            </a>
          </article>
        </div>
        <p class="dev-inline-note">
          Это ориентир. Финальная стоимость рассчитывается после брифа.
        </p>
      </div>
    </section>

    <!-- Breadcrumbs -->
    <nav class="dev-breadcrumbs" aria-label="breadcrumb">
      <div class="container">
        <ol>
          <li><a href="/ru/">Главная</a></li>
          <li aria-hidden="true">/</li>
          <li><span aria-current="page">Цены</span></li>
        </ol>
      </div>
    </nav>

    <!-- Pricing Section -->
    <section class="dev-section dev-section-alt" id="preturi">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Пакеты</span>
          <h2>Выберите подходящий вариант</h2>
          <p>Для малого бизнеса или личных проектов</p>
        </div>
        <div class="dev-pricing-grid">
          {
            packages.map((pkg) => (
              <article
                class={`dev-price-card ${pkg.featured ? "featured" : ""}`}
                id={pkg.id}
              >
                <h3>{pkg.name}</h3>
                <div class="dev-price">{pkg.price}</div>
                <p>{pkg.description}</p>
                <ul class="dev-price-features">
                  {pkg.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
                <p class="dev-price-note">* {pkg.note}</p>
                <a href="/ru/contact/" class="dev-btn dev-btn-primary">
                  Запросить предложение
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="dev-section">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Почему мы</span>
          <h2>Почему стоит выбрать нас?</h2>
          <p>Наши преимущества при работе с клиентами из Молдовы</p>
        </div>
        <div class="dev-why-grid">
          {
            whyChooseUs.map((w) => (
              <div class="dev-why-card">
                <div class="dev-why-icon">{w.icon}</div>
                <h3>{w.title}</h3>
                <p>{w.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Factors Section -->
    <section class="dev-section dev-section-alt" id="preturi-explicate">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Информация</span>
          <h2>Что влияет на цену?</h2>
          <p>Основные факторы, влияющие на итоговую стоимость</p>
        </div>
        <div class="dev-info-grid">
          {
            factors.map((f) => (
              <div class="dev-info-card">
                <h3>{f.title}</h3>
                <p>{f.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="dev-section">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Кластеры спроса</span>
          <h2>Отдельные страницы для разных коммерческих запросов</h2>
          <p>
            Страница цен хорошо отвечает на запросы о стоимости. Для остальных
            кластеров мы добавили отдельные landing page, чтобы не пытаться
            ранжировать один URL сразу по всем намерениям.
          </p>
        </div>
        <div class="dev-info-grid">
          {
            ruLandingCards.map((page) => (
              <a href={page.href} class="dev-info-card">
                <h3>{page.title}</h3>
                <p>{page.description}</p>
                <span class="dev-link-accent">Открыть страницу</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Addons Section -->
    <section class="dev-section" id="adaugiri">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Дополнительно</span>
          <h2>Дополнительные опции</h2>
          <p>Расширяйте выбранный пакет при необходимости</p>
        </div>
        <div class="dev-info-grid">
          {
            addons.map((a) => (
              <div class="dev-info-card">
                <h3>{a.title}</h3>
                <p>{a.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="dev-section dev-section-alt">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">Отзывы</span>
          <h2>Что говорят наши клиенты</h2>
          <p>Реальные отзывы о наших ценах и качестве</p>
        </div>
        <div class="dev-testimonials-grid">
          {
            testimonials.map((t) => (
              <div class="dev-testimonial">
                <p class="dev-testimonial-content">{t.content}</p>
                <div class="dev-testimonial-author">{t.author}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="dev-section" id="faq">
      <div class="container">
        <div class="dev-section-header">
          <span class="dev-section-tag">FAQ</span>
          <h2>Часто задаваемые вопросы</h2>
          <p>Практические детали о ценовых пакетах</p>
        </div>
        <div class="dev-faq-list">
          {
            faqs.map((faq) => (
              <details class="dev-faq-item">
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="dev-cta" id="contact">
      <div class="container">
        <div class="dev-cta-content">
          <h2>Нашли подходящий пакет?</h2>
          <p>
            Расскажите о ваших целях, и мы ответим персональным предложением.
          </p>
          <a
            href="/ru/contact/"
            class="dev-btn dev-btn-primary dev-btn-lg"
          >
            Связаться с нами
          </a>
        </div>
      </div>
    </section>

    <Footer lang="ru" />
    <script src="/script.js" defer></script>
  </body>
</html>

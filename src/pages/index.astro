---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { roLandingCards } from "../data/landingPages.ro";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "moldovawebsite.md",
      url: "https://moldovawebsite.md/",
      inLanguage: "ro-MD",
    },
    {
      "@type": "ProfessionalService",
      name: "moldovawebsite.md",
      description:
        "Creare site web în Moldova cu pachete de la 50€, web design în Chișinău: site de prezentare, magazin online, SEO on-page și mentenanță.",
      areaServed: { "@type": "Country", name: "Moldova" },
      url: "https://moldovawebsite.md/",
      email: "contact@moldovawebsite.md",
      telephone: "+37361211739",
      address: {
        "@type": "PostalAddress",
        streetAddress: "str. Ioana Radu 27/2",
        addressLocality: "Chișinău",
        addressCountry: "MD",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "Pot obține un site web ieftin fără să sacrific calitatea?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Da. Folosim componente optimizate și un proces eficient pentru a livra rapid un site modern, la preț accesibil.",
          },
        },
        {
          "@type": "Question",
          name: "Lucrați în Chișinău și în toată Moldova?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Da. Oferim servicii locale în Chișinău și colaborăm online cu clienți din toată Moldova.",
          },
        },
        {
          "@type": "Question",
          name: "Includeți SEO on-page?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Da. Setăm meta-taguri, structură corectă, viteza paginilor și schema JSON-LD pentru vizibilitate mai bună în căutări.",
          },
        },
        {
          "@type": "Question",
          name: "Faceți și magazine online?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Da. Implementăm magazine online cu catalog, coș, plăți și livrare, optimizate pentru conversie.",
          },
        },
      ],
    },
  ],
};

const services = [
  {
    icon: `🎨`,
    title: "Design modern & UX",
    description:
      "Interfețe curate, ușor de folosit, care cresc conversiile și încrederea.",
  },
  {
    icon: `⚡`,
    title: "Performanță & viteză",
    description:
      "Optimizare tehnică (LCP/CLS), caching și bune practici pentru timpi de încărcare rapidi.",
  },
  {
    icon: `🔍`,
    title: "SEO on-page pentru Moldova",
    description:
      "Structură corectă, meta-taguri, scheme JSON-LD și conținut localizat (Chișinău, MD).",
  },
  {
    icon: `🛒`,
    title: "Magazin online accesibil",
    description:
      "Implementare ecommerce cu plăți, livrare și catalog – fără costuri exagerate.",
  },
  {
    icon: `🛠️`,
    title: "Mentenanță & suport local",
    description:
      "Actualizări, securitate și asistență în română & rusă, când ai nevoie.",
  },
];

const linkedServices = [
  {
    icon: "🎨",
    title: "Design modern & UX",
    description:
      "Interfețe clare, ușor de folosit și orientate pe conversie pentru afaceri locale.",
    href: "/serviciiBlog/design-web/",
  },
  {
    icon: "⚡",
    title: "Performanță & viteză",
    description:
      "Implementare rapidă, structură curată și bune practici pentru timpi de încărcare buni.",
    href: "/serviciiBlog/dezvoltare-web/",
  },
  {
    icon: "🔍",
    title: "SEO on-page pentru Moldova",
    description:
      "Meta-taguri, structură și optimizare pentru căutări comerciale locale în Google.",
    href: "/serviciiBlog/seo-on-page/",
  },
  {
    icon: "🛒",
    title: "Magazin online accesibil",
    description:
      "Soluții ecommerce cu catalog, checkout, plăți și livrare pentru piața locală.",
    href: "/serviciiBlog/magazin-online/",
  },
  {
    icon: "🛠",
    title: "Mentenanță & suport local",
    description:
      "Actualizări, monitorizare și suport continuu pentru site-uri lansate deja.",
    href: "/serviciiBlog/mentenanta/",
  },
];

const testimonials = [
  {
    content:
      "După lansarea noului site, primim cu 40% mai multe cereri lunar. Echipa a lucrat rapid, clar și la un preț accesibil.",
    author: "Ion Popescu",
    role: "Proprietar afacere locală",
  },
  {
    content:
      "Ne-am mărit vânzările cu 35% în primele trei luni după lansarea magazinului online. Platforma este ușor de administrat.",
    author: "Maria Cojocaru",
    role: "Manager magazin online",
  },
  {
    content:
      "Apreciez foarte mult optimizările SEO implementate. Acum apărem în primele rezultate pentru căutări locale în Chișinău.",
    author: "Andrei Rusu",
    role: "Director marketing",
  },
  {
    content:
      "Un aspect esențial pentru noi a fost adaptarea site-ului pentru dispozitive mobile. Experiența este impecabilă!",
    author: "Elena Munteanu",
    role: "Antreprenor",
  },
];

const portfolio = [
  {
    image: "/assets/dentist-botanica.webp",
    title: "DentalCare Botanica",
    category: "Clinică Dentară",
    description:
      "Site de prezentare pentru o clinică dentară din sectorul Botanica, Chișinău. Include sistem de programări online.",
    features: ["Design responsive", "Programări online", "SEO local"],
  },
  {
    image: "/assets/pizza-riscani.webp",
    title: "Pizza Express Rîșcani",
    category: "Restaurant",
    description:
      "Mini-magazin online pentru o pizzerie din Rîșcani cu meniu digital, coș de comenzi și integrare cu servicii de livrare.",
    features: ["Meniu interactiv", "Sistem de comenzi", "Integrare livrare"],
  },
  {
    image: "/assets/salon-beauty.webp",
    title: "Beauty Studio Centru",
    category: "Salon Beauty",
    description:
      "Site elegant pentru un salon de înfrumusețare din centrul Chișinăului. Include galerie foto și rezervări online.",
    features: ["Galerie foto", "Rezervări online", "Design premium"],
  },
  {
    image: "/assets/r-ro-ai.webp",
    title: "R-RO AI – Asistent Juridic",
    category: "Aplicație Web AI",
    description:
      "Platformă AI pentru românii din diaspora. Generează reclamații ANPC, cereri despăgubire și ghiduri juridice.",
    features: ["Integrare AI", "Aplicație web PWA", "Design modern"],
    link: "https://r-ro.com",
  },
];

const process = [
  {
    number: "01",
    title: "Consultație gratuită",
    description:
      "Stabilim obiectivele, bugetul și tipul de site (prezentare, magazin online).",
  },
  {
    number: "02",
    title: "Design",
    description: "Propuneri vizuale & wireframe-uri centrate pe conversie.",
  },
  {
    number: "03",
    title: "Dezvoltare",
    description:
      "Implementăm rapid, cu bune practici de performanță & securitate.",
  },
  {
    number: "04",
    title: "Lansare & SEO",
    description: "Publicăm site-ul, configurăm SEO on-page și oferim suport.",
  },
];

const faqs = [
  {
    question: "Pot obține un site web ieftin fără să sacrific calitatea?",
    answer:
      "Da. Folosim componente optimizate și un proces eficient, astfel încât să livrezi rapid un site modern, la preț accesibil.",
  },
  {
    question: "Lucrați în Chișinău și în toată Moldova?",
    answer:
      "Da. Oferim servicii locale în Chișinău și colaborăm online cu clienți din toată Moldova.",
  },
  {
    question: "Includeți SEO on-page?",
    answer:
      "Da. Setăm meta-taguri, structură corectă, viteza paginilor și schema JSON-LD pentru vizibilitate mai bună în căutări.",
  },
  {
    question: "Faceți și magazine online?",
    answer:
      "Da. Implementăm magazine online cu catalog, coș, plăți și livrare, optimizate pentru conversie.",
  },
];
---

<!doctype html>
<html lang="ro">
  <head>
    <BaseHead
      title="Creare site web în Moldova | Prețuri de la 50€"
      description="Web design în Chișinău pentru siteuri de prezentare și magazine online. SEO on-page inclus, livrare rapidă, ofertă gratuită."
      canonicalUrl="https://moldovawebsite.md/"
      hreflangRo="https://moldovawebsite.md/"
      hreflangRu="https://moldovawebsite.md/ru/"
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <Header lang="ro" />

    <!-- Hero Section - Netflix Style Dark Hero -->
    <section class="nf-hero" id="acasa">
      <div class="container">
        <div class="nf-hero-content">
          <div class="nf-hero-badge">Disponibil pentru proiecte noi</div>
          <h1>Creare site web ieftin în Moldova</h1>
          <p class="nf-hero-subtitle">
            Site-uri moderne și rapide <strong>(Lighthouse 95+)</strong> care aduc
            clienți. Servicii locale: <strong>site de prezentare</strong>, <strong>magazin online</strong>,
            <strong>SEO on-page</strong> și <strong>mentenanță</strong>.
          </p>
          <div class="nf-hero-actions">
            <a href="/contact/" class="nf-btn nf-btn-primary nf-btn-lg">
              Solicită ofertă gratuită
            </a>
            <a href="#portofoliu" class="nf-btn nf-btn-ghost nf-btn-lg">
              Vezi portofoliu
            </a>
          </div>
          <div class="nf-hero-stats">
            <div class="nf-stat">
              <div class="nf-stat-value">95+</div>
              <div class="nf-stat-label">Lighthouse Score</div>
            </div>
            <div class="nf-stat">
              <div class="nf-stat-value">40%</div>
              <div class="nf-stat-label">Creștere medie</div>
            </div>
            <div class="nf-stat">
              <div class="nf-stat-value">24h</div>
              <div class="nf-stat-label">Timp răspuns</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="nf-section nf-section-alt" id="servicii">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Servicii</span>
          <h2>Soluții complete pentru afaceri mici</h2>
          <p>
            De la idee la lansare — transformăm viziunea ta în realitate
            digitală
          </p>
        </div>
        <div class="nf-services-grid">
          {
            linkedServices.map((service) => (
              <a href={service.href} class="nf-service-card">
                <div class="nf-service-icon">{service.icon}</div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="nf-section" id="cautari-populare">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Cautari Populare</span>
          <h2>Pagini create direct din cererea din Google</h2>
          <p>
            Aceste pagini raspund clusterelor comerciale care apar deja in GSC
            si au nevoie de o destinatie dedicata, nu doar de homepage sau
            preturi.
          </p>
        </div>
        <div class="nf-services-grid">
          {
            roLandingCards.map((page, index) => (
              <a href={page.href} class="nf-service-card">
                <div class="nf-service-icon">{String(index + 1).padStart(2, "0")}</div>
                <h3>{page.title}</h3>
                <p>{page.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Portfolio Section - Netflix Card Style -->
    <section class="nf-section" id="portofoliu">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Portofoliu</span>
          <h2>Exemple de site-uri create</h2>
          <p>Iată câteva exemple de site-uri pe care le-am creat pentru afaceri locale</p>
        </div>
        <div class="nf-portfolio-grid">
          {
            portfolio.map((item) => (
              <article class="nf-card">
                <div class="nf-card-image">
                  <img
                    src={item.image}
                    alt={item.title}
                    loading="lazy"
                    width="400"
                    height="220"
                  />
                  <div class="nf-card-overlay">
                    <span class="nf-card-category">{item.category}</span>
                  </div>
                </div>
                <div class="nf-card-content">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                  <ul class="nf-portfolio-features">
                    {item.features.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                  {item.link && (
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener"
                      class="nf-portfolio-link"
                    >
                      Vizitează site-ul →
                    </a>
                  )}
                </div>
              </article>
            ))
          }
        </div>
        <div class="nf-center-cta">
          <a href="/contact/" class="nf-btn nf-btn-primary nf-btn-lg">
            Solicită ofertă gratuită
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="nf-section nf-section-alt" id="testimoniale">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Testimoniale</span>
          <h2>De încredere pentru afaceri locale</h2>
          <p>Recomandări reale de la clienți mulțumiți</p>
        </div>
        <div class="nf-testimonials-grid">
          {
            testimonials.map((t) => (
              <div class="nf-testimonial">
                <div class="nf-testimonial-content">"{t.content}"</div>
                <div class="nf-testimonial-author">
                  <div class="nf-testimonial-avatar">
                    {t.author.split(" ").map((n) => n[0]).join("")}
                  </div>
                  <div class="nf-testimonial-info">
                    <span class="nf-testimonial-name">{t.author}</span>
                    <span class="nf-testimonial-role">{t.role}</span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="nf-section" id="preturi">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Prețuri</span>
          <h2>Prețuri transparente pentru afaceri mici</h2>
          <p>Alege soluția potrivită: site de prezentare, landing page, magazin online</p>
        </div>
        <div class="nf-pricing-grid">
          <div class="nf-pricing-card">
            <h3>Site de Prezentare</h3>
            <p>Perfect pentru afaceri care doresc prezență online profesională</p>
            <ul class="nf-pricing-features">
              <li>Design modern + 5 pagini</li>
              <li>Optimizare SEO on-page</li>
              <li>Formular de contact & hărți</li>
              <li>Responsive design</li>
              <li>Suport 30 zile inclus</li>
            </ul>
            <a href="/contact/" class="nf-btn nf-btn-outline nf-btn-block">
              Solicită ofertă
            </a>
          </div>
          <div class="nf-pricing-card nf-pricing-featured">
            <h3>Magazin Online</h3>
            <p>Soluție ecommerce completă pentru vânzări online</p>
            <ul class="nf-pricing-features">
              <li>Catalog produse + coș</li>
              <li>Metode de plată & livrare</li>
              <li>SEO tehnic & structură</li>
              <li>Panou administrare intuitiv</li>
              <li>Integrare curieri</li>
              <li>Suport 60 zile inclus</li>
            </ul>
            <a href="/contact/" class="nf-btn nf-btn-primary nf-btn-block">
              Solicită ofertă
            </a>
          </div>
          <div class="nf-pricing-card">
            <h3>SEO & Mentenanță</h3>
            <p>Menține site-ul tău actualizat și optimizat</p>
            <ul class="nf-pricing-features">
              <li>Actualizări & securitate</li>
              <li>Optimizări conținut & viteză</li>
              <li>Raportare lunară</li>
              <li>Backup automat zilnic</li>
              <li>Monitorizare uptime</li>
            </ul>
            <a href="/contact/" class="nf-btn nf-btn-outline nf-btn-block">
              Solicită ofertă
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="nf-section nf-section-alt" id="proces">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">Proces</span>
          <h2>Cum lucrăm — simplu și transparent</h2>
          <p>Proces clar de la consultație gratuită la lansare + SEO on-page</p>
        </div>
        <div class="nf-process-grid">
          {
            process.map((step) => (
              <div class="nf-process-step">
                <div class="nf-process-number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="nf-section" id="faq">
      <div class="container">
        <div class="nf-section-header">
          <span class="nf-section-tag">FAQ</span>
          <h2>Întrebări frecvente</h2>
          <p>Răspunsuri rapide pentru alegeri informate</p>
        </div>
        <div class="nf-faq-list">
          {
            faqs.map((faq) => (
              <details class="nf-faq-item">
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>Vrei un site web la preț accesibil în Moldova?</h2>
          <p>
            Spune-ne pe scurt ce îți dorești și îți trimitem o ofertă gratuită,
            personalizată pentru nevoile tale.
          </p>
          <a href="/contact/" class="nf-btn nf-btn-primary nf-btn-xl">
            Solicită ofertă gratuită
          </a>
        </div>
      </div>
    </section>

    <Footer lang="ro" />

    <script src="/script.js" defer></script>
  </body>
</html>


